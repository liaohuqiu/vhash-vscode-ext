{
  "name": "vhash-vscode-ext-v2",
  "displayName": "vHash Copy Path",
  "version": "0.0.16",
  "publisher": "vHash",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/liaohuqiu/vhash-vscode-ext"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vhashTools.copySelectionPathRange"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vhashTools.copySelectionPathRange",
        "title": "VHash: Copy Path With Line Range"
      }
    ],
    "keybindings": [
      {
        "command": "workbench.action.showCommands",
        "key": "shift+alt+p",
        "mac": "shift+cmd+p"
      },
      {
        "command": "workbench.files.action.showActiveFileInExplorer",
        "key": "shift+alt+e",
        "mac": "shift+cmd+e"
      },
      {
        "command": "workbench.action.findInFiles",
        "key": "shift+alt+f",
        "mac": "shift+cmd+f"
      },
      {
        "command": "workbench.action.quickOpen",
        "key": "shift+alt+o",
        "mac": "shift+cmd+o"
      },
      {
        "command": "workbench.action.previousEditor",
        "key": "shift+alt+[",
        "mac": "shift+cmd+["
      },
      {
        "command": "workbench.action.nextEditor",
        "key": "shift+alt+]",
        "mac": "shift+cmd+]"
      },
      {
        "command": "vhashTools.copySelectionPathRange",
        "key": "shift+alt+c",
        "mac": "shift+cmd+c",
        "when": "editorTextFocus"
      },
      {
        "command": "copyFilePath",
        "key": "shift+alt+c",
        "mac": "shift+cmd+c",
        "when": "!editorFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.3"
  }
}
