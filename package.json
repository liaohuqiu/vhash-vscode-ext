{
  "name": "vhash-vscode-ext-v1",
  "displayName": "vHash Tools",
  "version": "0.0.8",
  "publisher": "vHash",
  "repository": {
    "type": "git",
    "url": "https://example.com/local/vhash-vscode-ext.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vhashTools.copySelectionPathRange"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vhashTools.copySelectionPathRange",
        "title": "VHash: Copy Path With Line Range"
      }
    ],
    "keybindings": [
      {
        "command": "vhashTools.copySelectionPathRange",
        "key": "shift+cmd+c",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.3"
  }
}
