// VHash Tools 快捷键配置（JSONC 格式）
// 此文件为 user 级设置，会覆盖 Cursor/VS Code 的系统默认快捷键
// 可复制条目到 keybindings.json（支持 // 注释），安装扩展时会自动导入
//
// 跨平台说明：
//   - package.json 使用 "key"（Windows/Linux 默认）+ "mac"（macOS 覆盖）模式
//   - 用户 keybindings 使用 isMac / isWindows / isLinux when 条件
//   - macOS 使用 Cmd，Windows/Linux 使用 Alt
//
// 快捷键已定义在 package.json 的 contributes.keybindings 中，安装扩展即生效。
// 此处保留平台特定写法，方便手动复制到用户 keybindings 或调试参考。

[
  {
    // 打开命令面板
    "command": "workbench.action.showCommands",
    "key": "shift+cmd+p",
    "when": "isMac"
  },
  {
    // 打开命令面板
    "command": "workbench.action.showCommands",
    "key": "shift+alt+p",
    "when": "isWindows || isLinux"
  },
  {
    // 在文件浏览器中定位当前文件
    "command": "workbench.files.action.showActiveFileInExplorer",
    "key": "shift+cmd+e",
    "when": "isMac"
  },
  {
    // 在文件浏览器中定位当前文件
    "command": "workbench.files.action.showActiveFileInExplorer",
    "key": "shift+alt+e",
    "when": "isWindows || isLinux"
  },
  {
    // 全局搜索
    "command": "workbench.action.findInFiles",
    "key": "shift+cmd+f",
    "when": "isMac"
  },
  {
    // 全局搜索
    "command": "workbench.action.findInFiles",
    "key": "shift+alt+f",
    "when": "isWindows || isLinux"
  },
  {
    // 快速打开文件
    "command": "workbench.action.quickOpen",
    "key": "shift+cmd+o",
    "when": "isMac"
  },
  {
    // 快速打开文件
    "command": "workbench.action.quickOpen",
    "key": "shift+alt+o",
    "when": "isWindows || isLinux"
  },
  {
    // 切换到上一个编辑器标签页
    "command": "workbench.action.previousEditor",
    "key": "shift+cmd+[",
    "when": "isMac"
  },
  {
    // 切换到上一个编辑器标签页
    "command": "workbench.action.previousEditor",
    "key": "shift+alt+[",
    "when": "isWindows || isLinux"
  },
  {
    // 切换到下一个编辑器标签页
    "command": "workbench.action.nextEditor",
    "key": "shift+cmd+]",
    "when": "isMac"
  },
  {
    // 切换到下一个编辑器标签页
    "command": "workbench.action.nextEditor",
    "key": "shift+alt+]",
    "when": "isWindows || isLinux"
  },
  {
    // 复制文件路径与行号范围
    "command": "vhashTools.copySelectionPathRange",
    "key": "shift+cmd+c",
    "when": "isMac && editorTextFocus"
  },
  {
    // 复制文件路径与行号范围
    "command": "vhashTools.copySelectionPathRange",
    "key": "shift+alt+c",
    "when": "(isWindows || isLinux) && editorTextFocus"
  },
  {
    // 非编辑区时复制文件路径
    "command": "copyFilePath",
    "key": "shift+cmd+c",
    "when": "isMac && !editorFocus"
  },
  {
    // 非编辑区时复制文件路径
    "command": "copyFilePath",
    "key": "shift+alt+c",
    "when": "(isWindows || isLinux) && !editorFocus"
  }
]
